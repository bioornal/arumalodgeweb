# URLs secretas iCal de cada Google Calendar (una por unidad) — LECTURA de disponibilidad.
# En Google Calendar: Configuración del calendario > "Dirección secreta en formato iCal".
# Tratar como credenciales: NO commitear los valores reales (.env.local está en .gitignore).
ARUMA_ICS_YVYRA=
ARUMA_ICS_MBERU=
ARUMA_ICS_TATU=

# Service account de Google (ESCRITURA de eventos). NO commitear el valor real.
# El JSON completo de la clave del service account, en una sola línea.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_TIMEZONE=America/Argentina/Buenos_Aires
# IDs de calendario por unidad (el ...@group.calendar.google.com, presente en las URLs iCal).
# El service account debe tener permiso "Hacer cambios en los eventos" en los 3 calendarios.
ARUMA_CAL_YVYRA=
ARUMA_CAL_MBERU=
ARUMA_CAL_TATU=

# Mercado Pago — cobro con tarjeta (Checkout Bricks). Tratar como credenciales: NO commitear valores reales.
# Panel: https://www.mercadopago.com.ar/developers → Tus integraciones → Credenciales.
MERCADOPAGO_ACCESS_TOKEN=            # secreto, SOLO server. (Access Token; usar el de PRUEBA para sandbox)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=  # público, inicializa el Brick. (Public Key; usar el de PRUEBA para sandbox)
MERCADOPAGO_WEBHOOK_SECRET=          # firma del webhook (panel MP → Webhooks → "Clave secreta")
NEXT_PUBLIC_SITE_URL=                # opcional, base para notification_url del webhook (ej: https://aruma.com)

# Modo test de pagos: "1" emula un pago sin llamar a MP (para probar el almanaque). Vacío/0 en producción.
PAYMENTS_MOCK=
NEXT_PUBLIC_PAYMENTS_MOCK=           # espejo cosmético: solo decide qué UI muestra el paso Pago

# Modo de reservas: "whatsapp" pausa la reserva online (los CTAs derivan a WhatsApp
# con mensaje prellenado; /reservas redirige a /tarifas; los APIs de pago responden 503).
# Vacío = checkout online normal. Se inlinea en el build: cambiarla requiere redeploy.
NEXT_PUBLIC_BOOKING_MODE=

# Supabase (subsistema B). NO commitear valores reales.
NEXT_PUBLIC_SUPABASE_URL=https://dckpnzkvuzrajvakiusc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # publishable key (sb_publishable_...); cliente SSR para Auth
SUPABASE_SERVICE_ROLE_KEY=        # secreto, SOLO server (acceso a datos, bypassa RLS)

# Datos bancarios para transferencia (se muestran al huésped → NEXT_PUBLIC).
NEXT_PUBLIC_ARUMA_BANK_ALIAS=
NEXT_PUBLIC_ARUMA_BANK_CBU=
NEXT_PUBLIC_ARUMA_BANK_HOLDER=

# Panel admin (Supabase Auth). Emails autorizados, separados por coma.
ADMIN_EMAILS=spezialichristian@gmail.com

# Resend — email transaccional de confirmación. NO commitear el valor real.
# Panel: https://resend.com → API Keys.
RESEND_API_KEY=
# Remitente verificado en Resend (dominio propio). Para pruebas: onboarding@resend.dev
ARUMA_EMAIL_FROM=Aruma Lodge <onboarding@resend.dev>

# Google Analytics 4. Vacío = no se carga nada (dev y previews limpios).
# Panel: https://analytics.google.com → Administrar → Flujos de datos.
NEXT_PUBLIC_GA_ID=

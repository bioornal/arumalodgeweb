# node_modules plano (sin symlinks) para que el build de Netlify funcione en Windows.
# El plugin @netlify/plugin-nextjs copia node_modules y no puede recrear los symlinks
# de pnpm en Windows (EPERM). Con hoisted no hay symlinks que copiar.
node-linker=hoisted

# pnpm v11 corre un chequeo de deps antes de cada script y falla si hay build
# scripts "ignorados" (sharp, etc.). En el build de Netlify eso rompe. Lo desactivamos.
verify-deps-before-run=false
